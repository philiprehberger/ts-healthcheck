{
  "name": "@philiprehberger/healthcheck",
  "version": "0.2.1",
  "description": "Production readiness health check builder with typed check results",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "node --test"
  },
  "devDependencies": {
    "tsdown": "^0.22.7",
    "typescript": "^7.0.2",
    "unrun": "^0.3.1"
  },
  "keywords": [
    "health",
    "healthcheck",
    "monitoring",
    "kubernetes",
    "readiness"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/philiprehberger/ts-healthcheck.git"
  },
  "homepage": "https://github.com/philiprehberger/ts-healthcheck#readme",
  "bugs": {
    "url": "https://github.com/philiprehberger/ts-healthcheck/issues"
  },
  "author": "Philip Rehberger",
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false
}
