{
  "name": "@philiprehberger/healthcheck",
  "version": "0.1.0",
  "description": "Production readiness health check builder with typed check results",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" }, "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" } } },
  "files": ["dist"],
  "scripts": { "build": "tsup", "dev": "tsup --watch", "typecheck": "tsc --noEmit", "prepublishOnly": "npm run build" },
  "devDependencies": { "tsup": "^8.0.0", "typescript": "^5.0.0" },
  "keywords": ["health", "healthcheck", "monitoring", "kubernetes", "readiness"],
  "license": "MIT",
  "repository": { "type": "git", "url": "git+https://github.com/philiprehberger/healthcheck.git" },
  "homepage": "https://github.com/philiprehberger/healthcheck#readme",
  "bugs": { "url": "https://github.com/philiprehberger/healthcheck/issues" },
  "author": "Philip Rehberger", "engines": { "node": ">=18.0.0" }, "sideEffects": false
}
